////////////////////////////////////////////////////////////////////////////////////////////////////

theme "nightfox"

////////////////////////////////////////////////////////////////////////////////////////////////////

layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar"
        }
        children
    }

    tab name="Hub" focus=true {
        pane stacked=true split_direction="horizontal" {
            pane name="lab" focus=true
            pane name="grid"
            pane name="canvas"
        }
    }
}

////////////////////////////////////////////////////////////////////////////////////////////////////
